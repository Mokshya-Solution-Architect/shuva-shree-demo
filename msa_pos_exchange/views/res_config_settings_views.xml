<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ss_exchange" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ss.exchange</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_inventory_section']" position="inside">
                <setting string="Product Exchange Locations"
                         help="Returns quarantine, rework, scrap, and finished-goods source for no-refund POS exchanges."
                         id="ss_pos_exchange_locations">
                    <div class="content-group mt16">
                        <div class="row">
                            <label for="pos_exchange_return_location_id" string="Returns" class="col-lg-3 o_light_label"/>
                            <field name="pos_exchange_return_location_id" class="col-lg-9"/>
                        </div>
                        <div class="row">
                            <label for="pos_exchange_rework_location_id" string="Rework" class="col-lg-3 o_light_label"/>
                            <field name="pos_exchange_rework_location_id" class="col-lg-9"/>
                        </div>
                        <div class="row">
                            <label for="pos_exchange_scrap_location_id" string="Scrap" class="col-lg-3 o_light_label"/>
                            <field name="pos_exchange_scrap_location_id" class="col-lg-9"/>
                        </div>
                        <div class="row">
                            <label for="pos_exchange_stock_location_id" string="Finished Goods" class="col-lg-3 o_light_label"/>
                            <field name="pos_exchange_stock_location_id" class="col-lg-9"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>

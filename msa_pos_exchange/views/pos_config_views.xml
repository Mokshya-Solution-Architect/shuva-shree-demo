<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_ss_exchange" model="ir.ui.view">
        <field name="name">pos.config.form.ss.exchange</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Product Exchange" name="ss_pos_exchange">
                    <field name="exchange_return_location_id"/>
                    <field name="exchange_rework_location_id"/>
                    <field name="exchange_scrap_location_id"/>
                    <field name="exchange_stock_location_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

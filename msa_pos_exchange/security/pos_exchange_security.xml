<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_exchange_company_rule" model="ir.rule">
        <field name="name">POS Exchange: multi-company</field>
        <field name="model_id" ref="model_pos_exchange"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="pos_exchange_line_company_rule" model="ir.rule">
        <field name="name">POS Exchange Line: multi-company</field>
        <field name="model_id" ref="model_pos_exchange_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>

<odoo>
    <record id="view_shuva_pack_lot_wizard_form" model="ir.ui.view">
        <field name="name">shuva.pack.lot.wizard.form</field>
        <field name="model">shuva.pack.lot.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Pack Lots / Barcodes">
                <group>
                    <field name="move_id" readonly="1"/>
                    <field name="product_id"/>
                    <field name="picking_id"/>
                    <field name="pack_type_id"/>
                    <field name="pack_count"/>
                    <field name="total_qty"/>
                    <field name="distribute_equally"/>
                </group>
                <footer>
                    <button name="action_prepare_lines" type="object" string="Prepare Lines" class="btn-secondary"/>
                    <button name="action_generate" type="object" string="Generate Lots" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="name"/>
                        <field name="qty"/>
                        <field name="vendor_barcode"/>
                    </list>
                </field>
            </form>
        </field>
    </record>
</odoo>

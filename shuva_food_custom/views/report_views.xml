<odoo>
    <record id="view_shuva_barcode_history_pivot" model="ir.ui.view">
        <field name="name">shuva.barcode.history.pivot</field>
        <field name="model">shuva.barcode.history.report</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="product_id" type="row"/>
                <field name="lot_id" type="row"/>
                <field name="qty_done" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_shuva_barcode_history_tree" model="ir.ui.view">
        <field name="name">shuva.barcode.history.list</field>
        <field name="model">shuva.barcode.history.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="pack_barcode"/>
                <field name="picking_id"/>
                <field name="location_id"/>
                <field name="location_dest_id"/>
                <field name="qty_done"/>
            </list>
        </field>
    </record>
    <record id="action_shuva_barcode_history" model="ir.actions.act_window">
        <field name="name">Pack Barcode History</field>
        <field name="res_model">shuva.barcode.history.report</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>
    <record id="view_shuva_mrp_variance_pivot" model="ir.ui.view">
        <field name="name">shuva.mrp.variance.pivot</field>
        <field name="model">shuva.mrp.variance.report</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="production_id" type="row"/>
                <field name="component_id" type="row"/>
                <field name="planned_qty" type="measure"/>
                <field name="actual_qty" type="measure"/>
                <field name="variance_qty" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="view_shuva_mrp_variance_tree" model="ir.ui.view">
        <field name="name">shuva.mrp.variance.list</field>
        <field name="model">shuva.mrp.variance.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="component_id"/>
                <field name="planned_qty"/>
                <field name="actual_qty"/>
                <field name="variance_qty"/>
            </list>
        </field>
    </record>
    <record id="action_shuva_mrp_variance" model="ir.actions.act_window">
        <field name="name">MRP Consumption Variance</field>
        <field name="res_model">shuva.mrp.variance.report</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>
    <menuitem id="menu_shuva_reports" name="Reports" parent="menu_shuva_root" sequence="80"/>
    <menuitem id="menu_shuva_barcode_history" name="Pack Barcode History" parent="menu_shuva_reports"
              action="action_shuva_barcode_history"/>
    <menuitem id="menu_shuva_mrp_variance" name="MRP Consumption Variance" parent="menu_shuva_reports"
              action="action_shuva_mrp_variance"/>
</odoo>

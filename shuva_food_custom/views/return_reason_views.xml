<odoo>
    <record id="view_shuva_return_reason_tree" model="ir.ui.view">
        <field name="name">shuva.return.reason.list</field>
        <field name="model">shuva.return.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="return_type"/>
                <field name="location_dest_id"/>
                <field name="create_credit_note"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_shuva_return_reason_form" model="ir.ui.view">
        <field name="name">shuva.return.reason.form</field>
        <field name="model">shuva.return.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="return_type"/>
                        <field name="location_dest_id"/>
                        <field name="create_credit_note"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shuva_return_reason" model="ir.actions.act_window">
        <field name="name">Return Reasons</field>
        <field name="res_model">shuva.return.reason</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_shuva_return_reason" name="Return Reasons" parent="menu_shuva_config"
              action="action_shuva_return_reason"/>
</odoo>

<odoo>
    <record id="view_shuva_pack_type_tree" model="ir.ui.view">
        <field name="name">shuva.pack.type.list</field>
        <field name="model">shuva.pack.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_variable_qty"/>
                <field name="average_qty_per_pack"/>
                <field name="fixed_qty_per_pack"/>
                <field name="uom_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_shuva_pack_type_form" model="ir.ui.view">
        <field name="name">shuva.pack.type.form</field>
        <field name="model">shuva.pack.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="notes"/>
                    </group>
                    <group string="Quantity Rule">
                        <field name="is_variable_qty"/>
                        <field name="average_qty_per_pack" invisible="not is_variable_qty"/>
                        <field name="fixed_qty_per_pack" invisible="is_variable_qty"/>
                        <field name="uom_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shuva_pack_type" model="ir.actions.act_window">
        <field name="name">Pack Types / Alt Units</field>
        <field name="res_model">shuva.pack.type</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_shuva_root" name="Shuva Food" sequence="65"/>
    <menuitem id="menu_shuva_config" name="Configuration" parent="menu_shuva_root" sequence="90"/>
    <menuitem id="menu_shuva_pack_type" name="Pack Types / Alt Units" parent="menu_shuva_config"
              action="action_shuva_pack_type"/>
</odoo>

<odoo>
    <record id="purchase_order_form_shuva_alt" model="ir.ui.view">
        <field name="name">purchase.order.form.shuva.alt</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_qty']" position="after">
                <field name="shuva_alt_qty"/>
                <field name="shuva_pack_type_id"/>
                <field name="shuva_avg_qty_per_pack"/>
                <field name="shuva_estimated_qty" readonly="1"/>
                <field name="shuva_actual_received_qty" readonly="1"/>
                <field name="shuva_pack_note" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>

<odoo>
    <record id="mrp_production_form_shuva" model="ir.ui.view">
        <field name="name">mrp.production.form.shuva</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_shuva_finished_pack_wizard" type="object"
                        string="Generate Finished Pack Barcodes" class="btn-secondary"
                        invisible="state not in ('confirmed','progress','to_close')"/>
            </xpath>
            <xpath expr="//field[@name='product_qty']" position="after">
                <field name="shuva_alt_qty"/>
                <field name="shuva_pack_type_id"/>
                <field name="shuva_finished_pack_qty"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_template_form_default_packaging"
                model="ir.ui.view">
            <field name="name">product.template.form.default.packaging</field>
            <field name="model">product.template</field>
            <field name="inherit_id"
                   ref="product.product_template_form_view"/>
            <field name="arch" type="xml">

                <!-- Sales tab — default packaging after the sales group -->
                <xpath expr="//page[@name='sales']//group[@name='sale']"
                       position="inside">
                    <group string="Default Packaging"
                           name="default_sales_packaging">
                        <field name="default_sales_packaging_id"
                               domain="[('id', 'in', uom_ids + uom_id)]"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </xpath>

                <!-- Purchase tab — default packaging after the purchase group -->
                <xpath expr="//page[@name='purchase']//group[@name='purchase']"
                       position="inside">
                    <group string="Default Packaging"
                           name="default_purchase_packaging">
                        <field name="default_purchase_packaging_id"
                               options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </xpath>

            </field>
        </record>

    </data>
</odoo>

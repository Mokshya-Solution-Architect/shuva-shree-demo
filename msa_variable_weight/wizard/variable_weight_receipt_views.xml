<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_variable_weight_wizard_form" model="ir.ui.view">
            <field name="name">msa.variable.weight.wizard.form</field>
            <field name="model">msa.variable.weight.wizard</field>
            <field name="arch" type="xml">
                <form string="Record Variable Weights">
                    <field name="picking_id" invisible="1"/>
                    <field name="has_errors" invisible="1"/>
                    <sheet>
                        <div class="oe_title mb-3">
                            <h3>
                                Receipt: <field name="picking_id" readonly="1"
                                    context="{'formatted_display_name': False}"/>
                            </h3>
                        </div>

                        <div class="alert alert-info mb-3" role="alert">
                            <i class="fa fa-info-circle me-2"/>
                            Enter the actual weight for each physical unit received.
                            A unique lot (barcode) will be generated for each unit.
                        </div>

                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" default_order="product_id, sequence">
                                <field name="product_id" readonly="1" force_save="1"/>
                                <field name="sequence" string="Unit #" readonly="1"/>
                                <field name="lot_name" string="Lot / Barcode" force_save="1"/>
                                <field name="weight" string="Actual Weight" force_save="1"/>
                                <field name="uom_id" string="UoM" readonly="1"
                                    groups="uom.group_uom" force_save="1"
                                    widget="many2one_uom"/>
                                <field name="move_id" invisible="1" force_save="1"/>
                            </list>
                        </field>

                        <group class="mt-3" name="summary">
                            <group name="totals">
                                <field name="total_weight" string="Total Weight"
                                    widget="monetary" readonly="1"/>
                            </group>
                        </group>

                        <div class="alert alert-warning" role="alert"
                            invisible="not has_errors">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            Some weight entries are zero or negative.
                            All weights must be greater than zero to proceed.
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Confirm &amp; Validate"
                            type="object" class="btn-primary"
                            invisible="has_errors"
                            data-hotkey="q"/>
                        <button name="action_confirm" string="Confirm &amp; Validate"
                            type="object" class="btn-primary disabled"
                            invisible="not has_errors"
                            disabled="1"
                            title="Fix zero/negative weights first"/>
                        <button name="action_cancel" string="Cancel"
                            type="object" class="btn-secondary"
                            data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
